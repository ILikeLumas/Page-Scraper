{
  "sites": [
    {
      "name": "books-demo",
      "parser": "books_demo",
      "urls": [
        "https://books.local/catalogue/page-1.html",
        "https://books.local/catalogue/page-2.html",
        "https://books.local/catalogue/page-missing.html"
      ],
      "item_container": ".product-card",
      "selectors": [
        {
          "field": "title",
          "selector": ".title",
          "required": true
        },
        {
          "field": "price",
          "selector": ".price",
          "required": true
        },
        {
          "field": "availability",
          "selector": ".availability",
          "required": true
        },
        {
          "field": "detail_url",
          "selector": ".title a",
          "attribute": "href"
        }
      ],
      "required_fields": ["title", "price", "availability"],
      "optional_fields": ["detail_url"],
      "rate_limit": {
        "requests_per_second": 3.0
      },
      "retry_policy": {
        "max_attempts": 3,
        "base_delay_seconds": 0.01,
        "backoff_multiplier": 2.0,
        "retryable_statuses": [408, 429, 500, 502, 503, 504]
      }
    }
  ]
}

